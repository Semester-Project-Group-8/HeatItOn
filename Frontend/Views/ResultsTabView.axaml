<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Frontend.ViewModels"
             x:Class="Frontend.Views.ResultsTabView"
             x:DataType="vm:ResultsTabViewModel">
    <DockPanel>
        <!-- LEFT SIDEBAR -->
        <Border DockPanel.Dock="Left"
                Width="240"
                Padding="8"
                BorderBrush="Gray"
                BorderThickness="0,0,1,0">
            <StackPanel Spacing="8">
                <TextBlock Text="Results"
                           FontWeight="Bold" />
                <ListBox
                    ItemsSource="{Binding OptimizedResults}"
                    SelectedItem="{Binding SelectedOptimizedResult}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <!-- Empty state -->
                <TextBlock Text="No optimization results available yet"
                           IsVisible="{Binding HasNoOptimizedResults}"
                           Opacity="0.6"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>
        <!-- TOP SEARCH BAR -->
        <Border DockPanel.Dock="Top"
                Padding="8"
                BorderBrush="Gray"
                BorderThickness="0,0,0,1"
                IsVisible="{Binding IsResultSelected}">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <StackPanel>
                    <TextBlock Text="From" />
                    <CalendarDatePicker x:Name="SearchFromDatePicker" />
                    <TimePicker x:Name="SearchFromTimePicker" />
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="To" />
                    <CalendarDatePicker x:Name="SearchToDatePicker" />
                    <TimePicker x:Name="SearchToTimePicker" />
                </StackPanel>

                <StackPanel VerticalAlignment="Bottom">
                    <Button Content="Search" Click="OnSearchClick" />
                    <Button Content="Clear" Click="OnClearClick" />
                </StackPanel>
            </StackPanel>
        </Border>
        <!-- MAIN CONTENT -->
        <Border IsVisible="{Binding IsResultSelected}"
                Padding="8">
            <DataGrid ItemsSource="{Binding Rows}"
                      AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Hour"
                                        Binding="{Binding Hour}" />

                    <DataGridTextColumn Header="Active Assets"
                                        Binding="{Binding ActiveAssets}" />

                    <DataGridTextColumn Header="Heat Produced (MW)"
                                        Binding="{Binding HeatProduced}" />

                    <DataGridTextColumn Header="Electricity (MW)"
                                        Binding="{Binding Electricity}" />

                    <DataGridTextColumn Header="CO₂ Produced"
                                        Binding="{Binding CO2Produced}" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
        <!-- Empty state -->
        <Border Background="#10AAAAAA"
                IsVisible="{Binding !IsResultSelected}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
                <TextBlock Text="No data to display"
                           FontSize="18"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center" />
                <TextBlock
                    Text="Select a run on the left to view its results."
                    Opacity="0.7"
                    HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </DockPanel>
</UserControl>