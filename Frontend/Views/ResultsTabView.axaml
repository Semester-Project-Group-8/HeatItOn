<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Frontend.ViewModels"
             xmlns:models="using:Frontend.Models"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Frontend.Views.ResultsTabView"
             x:DataType="vm:ResultsTabViewModel">

    <Design.DataContext>
        <vm:ResultsTabViewModel/>
    </Design.DataContext>

    <Grid Margin="10" ColumnDefinitions="260,*" ColumnSpacing="12">
        <Border Grid.Column="0" BorderBrush="Black" BorderThickness="1" Padding="8">
            <StackPanel>
                <TextBlock Text="Result Lists" FontSize="18" Margin="0,0,0,8"/>
                <ListBox ItemsSource="{Binding ResultLists}"
                         SelectedItem="{Binding SelectedResultList}"
                         MaxHeight="600">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:ResultList">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{Binding Id, StringFormat='#{0}'}"/>
                                <TextBlock Text="{Binding TimeFrom, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" RowDefinitions="Auto,Auto,*" RowSpacing="10">
            <TextBlock Grid.Row="0" Text="Results" FontSize="20"/>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
                <TextBox Width="170"
                         Watermark="From yyyy-MM-dd HH:mm"
                         Text="{Binding SearchFrom}"/>
                <TextBox Width="170"
                         Watermark="To yyyy-MM-dd HH:mm"
                         Text="{Binding SearchTo}"/>
                <Button Content="Search" Click="OnSearchClick"/>
                <Button Content="Clear" Click="OnClearClick"/>
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"/>
            </StackPanel>

            <Grid Grid.Row="2" RowDefinitions="Auto,*" RowSpacing="6">
                <Grid Grid.Row="0" ColumnDefinitions="220,*,170,150" ColumnSpacing="8">
                    <TextBlock Grid.Column="0" Text="Hour" FontWeight="Bold"/>
                    <TextBlock Grid.Column="1" Text="Active Generators" FontWeight="Bold"/>
                    <TextBlock Grid.Column="2" Text="Electricity Consumed" FontWeight="Bold"/>
                    <TextBlock Grid.Column="3" Text="Total Net Price" FontWeight="Bold"/>
                </Grid>

                <Border Grid.Row="1" BorderBrush="Black" BorderThickness="1" Padding="4">
                    <ListBox ItemsSource="{Binding TableRows}">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:ResultTableRow">
                                <Grid ColumnDefinitions="220,*,170,150" ColumnSpacing="8">
                                    <TextBlock Grid.Column="0" Text="{Binding Hour}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding ActiveGenerators}" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Column="2" Text="{Binding ElectricityConsumed}"/>
                                    <TextBlock Grid.Column="3" Text="{Binding TotalNetPrice}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Grid>
        </Grid>
    </Grid>

</UserControl>