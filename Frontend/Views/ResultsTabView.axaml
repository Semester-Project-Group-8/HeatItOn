<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Frontend.ViewModels"
             xmlns:avalonia="clr-namespace:LiveChartsCore.SkiaSharpView.Avalonia;assembly=LiveChartsCore.SkiaSharpView.Avalonia"
             x:Class="Frontend.Views.ResultsTabView"
             x:DataType="vm:ResultsTabViewModel">
    <DockPanel>
        <!-- LEFT SIDEBAR -->
        <Border DockPanel.Dock="Left"
                Width="240"
                Padding="8"
                BorderBrush="Gray"
                BorderThickness="0,0,1,0">
            <StackPanel Spacing="8">
                <TextBlock Text="Results"
                           FontWeight="Bold" />
                <ListBox
                    ItemsSource="{Binding OptimizedResults}"
                    SelectedItem="{Binding SelectedOptimizedResult}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <!-- Empty state -->
                <TextBlock Text="No optimization results available yet"
                           IsVisible="{Binding HasNoOptimizedResults}"
                           Opacity="0.6"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>
        <!-- TOP SEARCH BAR -->
        <Border DockPanel.Dock="Top"
                Padding="8"
                BorderBrush="Gray"
                BorderThickness="0,0,0,1"
                IsVisible="{Binding IsResultSelected}">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <StackPanel>
                    <TextBlock Text="From" />
                    <CalendarDatePicker x:Name="SearchFromDatePicker" />
                    <TimePicker x:Name="SearchFromTimePicker" />
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="To" />
                    <CalendarDatePicker x:Name="SearchToDatePicker" />
                    <TimePicker x:Name="SearchToTimePicker" />
                </StackPanel>

                <StackPanel VerticalAlignment="Bottom">
                    <Button Content="Search" Click="OnSearchClick" />
                    <Button Content="Clear" Click="OnClearClick" />
                </StackPanel>
                <Button Content="Export" Command="{Binding Export}"></Button>
            </StackPanel>
        </Border>
        <!-- MAIN CONTENT -->
        <Grid RowDefinitions="Auto,*">

            <!-- DataGrid -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          IsVisible="{Binding IsResultSelected}">
                <StackPanel Spacing="16">
                    <DataGrid
                        Margin="20"
                        ItemsSource="{Binding Rows}"
                        AutoGenerateColumns="False"
                        GridLinesVisibility="All"
                        BorderBrush="Black"
                        BorderThickness="1"
                        MaxHeight="400">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time" 
                                                Binding="{Binding Hour}" 
                                                IsReadOnly="True"/>
                            
                            <DataGridTextColumn Header="Active Assets" 
                                                Binding="{Binding ActiveAssets}" 
                                                IsReadOnly="True"/>
                            
                            <DataGridTextColumn Header="Heat (MWh)" 
                                                Binding="{Binding HeatProduced}" 
                                                IsReadOnly="True"/>
                            
                            <DataGridTextColumn Header="Electricity (MWh)" 
                                                Binding="{Binding Electricity}" 
                                                IsReadOnly="True"/>
                            
                            <DataGridTextColumn Header="CO2 (kg)" 
                                                Binding="{Binding Co2Produced}" 
                                                IsReadOnly="True"/>
                            
                            <DataGridTextColumn Header="ProductionCost (DKK)"
                                                Binding="{Binding ProductionCost}" 
                                                IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <!-- Charts -->
                    <StackPanel>
                        <TextBlock Text="Heat produced per hour (MWh)"
                                   HorizontalAlignment="Center"
                                   FontWeight="Bold"
                                   FontSize="16" />
                        <Border Background="#F8FAFC"
                                BorderBrush="#D6DCE5"
                                BorderThickness="1"
                                CornerRadius="8"
                                Margin="20,10,20,0"
                                Padding="12">
                            <avalonia:CartesianChart
                                MinHeight="380"
                                MinWidth="400"
                                Series="{Binding HeatChartSeries}"
                                XAxes="{Binding TimeAxis}"
                                YAxes="{Binding HeatAxis}"
                                FindingStrategy="CompareOnlyXTakeClosest"
                                TooltipPosition="Top"
                                TooltipTextSize="14"
                                TooltipBackgroundPaint="#F8FAFC"
                                TooltipTextPaint="#111827" />
                        </Border>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Generator share for selected time range"
                                   HorizontalAlignment="Center"
                                   FontWeight="Bold"
                                   FontSize="16" />
                        <Border Background="#F8FAFC"
                                BorderBrush="#D6DCE5"
                                BorderThickness="1"
                                CornerRadius="8"
                                Margin="20,10,20,0"
                                Padding="12">
                            <Grid ColumnDefinitions="*,200" RowDefinitions="Auto">
                                <avalonia:PieChart
                                    Grid.Column="0"
                                    MinHeight="320"
                                    MinWidth="400"
                                    Series="{Binding GeneratorUsagePieSeries}" />

                                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding GeneratorUsageLegend}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:GeneratorLegendItem">
                                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="6">
                                                    <Rectangle Width="16" Height="16" Fill="{Binding Fill}" RadiusX="2" RadiusY="2" />
                                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Margin="6,0,0,0" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Production cost per hour (DKK)"
                                   HorizontalAlignment="Center"
                                   FontWeight="Bold"
                                   FontSize="16" />
                        <Border Background="#F8FAFC"
                                BorderBrush="#D6DCE5"
                                BorderThickness="1"
                                CornerRadius="8"
                                Margin="20,10,20,0"
                                Padding="12">
                            <avalonia:CartesianChart
                                MinHeight="380"
                                MinWidth="400"
                                Series="{Binding CostChartSeries}"
                                XAxes="{Binding TimeAxis}"
                                YAxes="{Binding CostAxis}"
                                FindingStrategy="CompareOnlyXTakeClosest"
                                TooltipPosition="Top"
                                TooltipTextSize="14"
                                TooltipBackgroundPaint="#F8FAFC"
                                TooltipTextPaint="#111827" />
                        </Border>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="Electricity used/Generated per hour (MWh)"
                                   HorizontalAlignment="Center"
                                   FontWeight="Bold"
                                   FontSize="16" />
                        <Border Background="#F8FAFC"
                                BorderBrush="#D6DCE5"
                                BorderThickness="1"
                                CornerRadius="8"
                                Margin="20,10,20,0"
                                Padding="12">
                            <avalonia:CartesianChart
                                MinHeight="380"
                                MinWidth="400"
                                Series="{Binding ElectricityChartSeries}"
                                XAxes="{Binding TimeAxis}"
                                YAxes="{Binding ElectricityAxis}"
                                FindingStrategy="CompareOnlyXTakeClosest"
                                TooltipPosition="Top"
                                TooltipTextSize="14"
                                TooltipBackgroundPaint="#F8FAFC"
                                TooltipTextPaint="#111827" />
                        </Border>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="CO2 produced by hour"
                                   HorizontalAlignment="Center"
                                   FontWeight="Bold"
                                   FontSize="16" />
                        <Border Background="#F8FAFC"
                                BorderBrush="#D6DCE5"
                                BorderThickness="1"
                                CornerRadius="8"
                                Margin="20,10,20,0"
                                Padding="12">
                            <avalonia:CartesianChart
                                MinHeight="380"
                                MinWidth="400"
                                Series="{Binding Co2ChartSeries}"
                                XAxes="{Binding TimeAxis}"
                                YAxes="{Binding Co2Axis}"
                                FindingStrategy="CompareOnlyXTakeClosest"
                                TooltipPosition="Top"
                                TooltipTextSize="14"
                                TooltipBackgroundPaint="#F8FAFC"
                                TooltipTextPaint="#111827" />
                        </Border>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- Empty state -->
            <Border Grid.Row="0" Grid.RowSpan="2"
                    Background="#10AAAAAA"
                    IsVisible="{Binding !IsResultSelected}">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="8">
                    <TextBlock Text="No data to display"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Select a run on the left to view its results."
                               Opacity="0.7" />
                </StackPanel>
            </Border>

        </Grid>
    </DockPanel>
</UserControl>