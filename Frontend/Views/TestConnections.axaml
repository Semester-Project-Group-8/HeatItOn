<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Frontend.Views.TestConnections"
        Title="TestConnections">
    <StackPanel>
        <ListBox 
            Name="resultBox"
            Width="780"
            Height="350"
            Margin="10"
            Background="Gray">
        </ListBox>
        <Grid ColumnDefinitions="*,*,*" RowDefinitions="*,*">
            <Button Click="RequestAllSourceButtonClick" Grid.Column="0" Grid.Row="0">
                Request all source
            </Button>
            <Button Click="RequestAllAssetButtonClick" Grid.Column="0" Grid.Row="1">Request all assets</Button>
            
            <Button Click="AddSourceButtonClick" Grid.Column="1" Grid.Row="0">
                 Add source
            </Button>
            <Button Click="AddAssetButtonClick" Grid.Column="1" Grid.Row="1">Add assets</Button>
            
            <Button Click="DeleteButtonClick" Grid.Column="2" Grid.Row="0">
                Delete source
            </Button>
            <Button Click="DeleteAssetButtonClick" Grid.Column="2" Grid.Row="1">Delete assets</Button>
        </Grid>
    </StackPanel>
</Window>
