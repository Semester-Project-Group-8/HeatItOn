<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Frontend.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Frontend.Views.AddAssetDialog"
             x:DataType="vm:AddAssetDialogViewModel"
             Background="White"
             BorderBrush="Black"
             BorderThickness="2"
             Padding="20">

    <UserControl.Styles>
        <Style Selector="TextBox:error">
            <Setter Property="BorderBrush" Value="Red"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
    </UserControl.Styles>
    
    <Grid RowDefinitions="Auto,*,Auto" MinWidth="500" MinHeight="600">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
            <TextBlock Grid.Column="0"
                       Text="{Binding DialogTitle}"
                       FontSize="22" FontWeight="Bold"
                       Foreground="#E06020"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1"
                    Content="✕"
                    Width="36" Height="36"
                    FontSize="14"
                    Background="Transparent"
                    BorderBrush="#D0D0D0"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="0"
                    VerticalContentAlignment="Center"
                    HorizontalContentAlignment="Center"
                    Command="{Binding CancelCommand}"/>
        </Grid>
        <Rectangle Grid.Row="0" Height="1" VerticalAlignment="Bottom"
                   HorizontalAlignment="Stretch" Fill="#E0E0E0"/>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">

            <StackPanel Spacing="15" Margin="0,12,0,20">
                
                <StackPanel Spacing="5">
                    <TextBlock Text="Name *" FontSize="14" FontWeight="Bold"/>
                    <TextBox Text="{Binding Name}"
                             Padding="10"
                             Height="40"
                             CornerRadius="10,10,10,10" 
                             Watermark="Enter asset name"/>
                </StackPanel>

                <StackPanel Spacing="5">
                    <TextBlock Text="Max Heat" FontSize="14" FontWeight="Bold"/>
                    <TextBox Text="{Binding MaxHeat}"
                             Padding="10"
                             Height="40"
                             CornerRadius="10,10,10,10" 
                             Watermark="Enter max heat"
                             ToolTip.Tip="Numbers only"/>
                </StackPanel>

                <StackPanel Spacing="5">
                    <TextBlock Text="Production Cost" FontSize="14" FontWeight="Bold"/>
                    <TextBox Text="{Binding ProductionCost}"
                             Padding="10"
                             Height="40"
                             CornerRadius="10,10,10,10" 
                             Watermark="Enter production cost"
                             ToolTip.Tip="Numbers only"/>
                </StackPanel>

                <StackPanel Spacing="5">
                    <TextBlock Text="CO2 Emission" FontSize="14" FontWeight="Bold"/>
                    <TextBox Text="{Binding CO2Emission}"
                             Padding="10"
                             Height="40"
                             CornerRadius="10,10,10,10" 
                             Watermark="Enter CO2 emission"
                             ToolTip.Tip="Numbers only"/>
                </StackPanel>

                <StackPanel Spacing="5">
                    <TextBlock Text="Gas Consumption" FontSize="14" FontWeight="Bold"/>
                    <TextBox Text="{Binding GasConsumption}"
                             Padding="10"
                             Height="40"
                             CornerRadius="10,10,10,10" 
                             Watermark="Enter gas consumption"
                             ToolTip.Tip="Numbers only"/>
                </StackPanel>

                <StackPanel Spacing="5">
                    <TextBlock Text="Oil Consumption" FontSize="14" FontWeight="Bold"/>
                    <TextBox Text="{Binding OilConsumption}"
                             Padding="10"
                             Height="40"
                             CornerRadius="10,10,10,10" 
                             Watermark="Enter oil consumption"
                             ToolTip.Tip="Numbers only"/>
                </StackPanel>

                <StackPanel Spacing="5">
                    <TextBlock Text="Max Electricity" FontSize="14" FontWeight="Bold"/>
                    <TextBox Text="{Binding MaxElectricity}"
                             Padding="10"
                             Height="40"
                             CornerRadius="10,10,10,10" 
                             Watermark="Enter max electricity"
                             ToolTip.Tip="Numbers only"/>
                </StackPanel>
                <StackPanel Spacing="5">
                    <TextBlock Text="Image" FontSize="14" FontWeight="Bold"/>
                    <TextBox Text="{Binding Image}"
                             Padding="10"
                             CornerRadius="10,10,10,10" 
                             Height="40"
                             Watermark="example.jpg"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" ColumnDefinitions="*,12,*,12,*" RowDefinitions="Auto" Margin="0,20,0,0">
            <!-- Cancel: outlined style, always left -->
            <Button Grid.Column="0"
                    Content="Cancel"
                    Height="46"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Background="White"
                    Foreground="#E06020"
                    BorderBrush="#E06020"
                    BorderThickness="2"
                    CornerRadius="10"
                    Padding="12,0"
                    HorizontalContentAlignment="Center"
                    Command="{Binding CancelCommand}"/>

            <!-- Delete: red outlined style, middle, only in edit mode -->
            <Button Grid.Column="2"
                    Content="Delete"
                    Height="46"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Background="White"
                    Foreground="#CC2200"
                    BorderBrush="#CC2200"
                    BorderThickness="2"
                    CornerRadius="10"
                    Padding="12,0"
                    HorizontalContentAlignment="Center"
                    Command="{Binding DeleteCommand}"
                    IsVisible="{Binding IsEditMode}"/>

            <!-- Submit: solid orange, always right -->
            <Button Grid.Column="4"
                    Content="{Binding SubmitButtonText}"
                    Height="46"
                    FontSize="14"
                    FontWeight="Bold"
                    Background="#E06020"
                    Foreground="White"
                    BorderThickness="0"
                    CornerRadius="10"
                    Padding="12,0"
                    HorizontalContentAlignment="Center"
                    Command="{Binding SubmitCommand}"/>
        </Grid>
    </Grid>
</UserControl>
