<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Frontend.ViewModels"
             xmlns:v="using:Frontend.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="Frontend.Views.AssetsTabView"
             x:DataType="vm:AssetsTabViewModel">

    <UserControl.Styles>
        <Style Selector="ToggleButton.asset-card">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Black"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="308"/>
            <Setter Property="Height" Value="300"/>
            <Setter Property="Padding" Value="10"/>

        </Style>
        <Style Selector="Button.card-corner-btn">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Panel.ZIndex" Value="10"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="Black"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Content" Value="  ..."/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style Selector="StackPanel.asset-card-content">
            <Setter Property="Margin" Value="0,24,0,0"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="*">
        <SplitView Grid.Row="0" IsPaneOpen="True" OpenPaneLength="200" PanePlacement="Left"
                   DisplayMode="Inline"
                   IsEnabled="{Binding CurrentDialog, Converter={x:Static ObjectConverters.IsNull}}">
            <SplitView.Pane>
                <DockPanel LastChildFill="False">
                    <RadioButton DockPanel.Dock="Top"
                                 FontSize="18"
                                 Margin="15,15,15,7.5"
                                 Content="Scenario 1"
                                 GroupName="Scenarios"
                                 IsChecked="{Binding IsScenario1Selected}"/>

                    <RadioButton DockPanel.Dock="Top"
                                 FontSize="18"
                                 Margin="15,7.5,15,7.5"
                                 Content="Scenario 2"
                                 GroupName="Scenarios"
                                 IsChecked="{Binding IsScenario2Selected}"/>

                    <RadioButton DockPanel.Dock="Top"
                                 FontSize="18"
                                 Margin="15,7.5,15,15"
                                 Content="Custom"
                                 GroupName="Scenarios"
                                 IsChecked="{Binding IsCustomScenarioSelected}"/>
                </DockPanel>
            </SplitView.Pane>
            <SplitView.Content>
                <Grid RowDefinitions="Auto,*,Auto" Margin="5">
                    <TextBlock Grid.Row="0"
                               IsVisible="{Binding HasStatusMessage}"
                               Text="{Binding StatusMessage}"
                               Margin="0,0,0,8"
                               Opacity="0.8"/>
                    <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto" Margin="0,8,0,0">
                        <Button Grid.Column="0" Content="+Add" Width="100" Height="50" FontSize="30"
                                Command="{Binding OpenAddAssetDialogCommand}"/>
                        <Button Grid.Column="2" Content="Done" Width="100" Height="50" FontSize="30"/>
                    </Grid>
                    <ScrollViewer Grid.Row="1"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding AssetItems}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" ItemWidth="318" ItemHeight="310"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ToggleButton Classes="asset-card"
                                                  Margin="0,0,10,10"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Top"
                                                  HorizontalContentAlignment="Stretch"
                                                  VerticalContentAlignment="Stretch"
                                                  IsChecked="{Binding IsSelected}">
                                        <Grid>
                                            <StackPanel Classes="asset-card-content" Spacing="8">
                                                <Image Source="{Binding ImagePath}"
                                                       Height="100"
                                                       Stretch="UniformToFill"/>
                                                <TextBlock Text="{Binding Name}"/>
                                                <ItemsControl ItemsSource="{Binding Details}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding}"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                            <Button Classes="card-corner-btn"
                                                    Command="{Binding EditCommand}"/>
                                        </Grid>
                                    </ToggleButton>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </SplitView.Content>
        </SplitView>

        <Panel Grid.Row="0" 
               Background="Black"
               Opacity="0.3"
               IsVisible="{Binding CurrentDialog, Converter={x:Static ObjectConverters.IsNotNull}}"
               IsHitTestVisible="True"/>

        <Panel Grid.Row="0"
               IsVisible="{Binding CurrentDialog, Converter={x:Static ObjectConverters.IsNotNull}}"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               IsHitTestVisible="True">
            <v:AddAssetDialog DataContext="{Binding CurrentDialog}"/>
        </Panel>
    </Grid>
</UserControl>